<style>
  .avm-video {
    background: #F7F7F5;
    padding: 80px 0;
  }

  .avm-video__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2.4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .avm-video__label {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #B87D2A;
    margin: 0 0 1.4rem;
    display: block;
  }

  .avm-video__accent-line {
    display: block;
    width: 40px;
    height: 2px;
    background: #B87D2A;
    margin-bottom: 1.6rem;
  }

  .avm-video__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2.8rem, 3.8vw, 4.4rem);
    font-weight: 700;
    color: #0A1F44;
    margin: 0 0 2rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .avm-video__body {
    font-family: var(--font-body-family);
    font-size: 1.7rem;
    line-height: 1.75;
    color: #444;
    margin: 0;
  }

  .avm-video__embed-wrap {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 12px 48px rgba(10, 31, 68, 0.16);
    background: #000;
    aspect-ratio: 16 / 9;
    width: 100%;
  }

  .avm-video__embed-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  @media screen and (max-width: 899px) {
    .avm-video__inner {
      grid-template-columns: 1fr;
      gap: 3.2rem;
    }

    .avm-video {
      padding: 60px 0;
    }
  }
</style>

<section class="avm-video">
  <div class="avm-video__inner">
    <div class="avm-video__text">
      <span class="avm-video__label">Who We Are</span>
      <span class="avm-video__accent-line" aria-hidden="true"></span>
      <h2 class="avm-video__heading">Supplying Surgical Excellence Since 1996</h2>
      <p class="avm-video__body">AVM Healthcare Products Pvt. Ltd. is a New Delhi–based manufacturer and supplier of advanced quality surgical instruments and medical devices. We design, develop, and supply instruments across neurosurgery, general surgery, cardiovascular, gynaecology, plastic surgery, and more — serving premier institutions including AIIMS, Medanta, Fortis, Apollo, and KEM Hospital.</p>
    </div>
    <div class="avm-video__media">
      <div class="avm-video__embed-wrap">
        <iframe
          src="https://www.youtube.com/embed/_QNRNKJiNuA"
          title="Who We Are — AVM Healthcare Products"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AVM Video Intro",
  "settings": [],
  "presets": [
    {
      "name": "AVM Video Intro"
    }
  ]
}
{% endschema %}
