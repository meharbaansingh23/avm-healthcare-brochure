<style>
  .avm-video {
    background: #F5F5F3;
    padding: var(--section-pad, 120px) 0;
  }

  .avm-video__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .avm-video__label {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #2563EB;
    margin-bottom: 1.2rem;
  }

  .avm-video__h2 {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(32px, 3.5vw, 44px);
    font-weight: 400;
    color: #0A1628;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 1.6rem;
  }

  .avm-video__body {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: #64748B;
    line-height: 1.85;
    margin: 0 0 2rem;
  }

  .avm-video__pullquote {
    border-left: 3px solid #2563EB;
    padding-left: 1.25rem;
    margin: 0;
    font-family: 'DM Serif Display', Georgia, serif;
    font-style: italic;
    font-size: 20px;
    color: #0A1628;
    line-height: 1.4;
  }

  .avm-video__embed-wrap {
    position: relative;
    background: #0A1628;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    box-shadow: 0 20px 60px rgba(10,22,40,0.18);
  }

  .avm-video__embed-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  @media screen and (max-width: 1024px) {
    .avm-video__inner { gap: 4rem; }
  }

  @media screen and (max-width: 767px) {
    .avm-video__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .avm-video { padding: 64px 0; }
    .avm-video__inner { padding: 0 1.5rem; }
  }
</style>

<section class="avm-video">
  <div class="avm-video__inner">
    <div>
      <span class="avm-video__label">Who we are</span>
      <h2 class="avm-video__h2">Supplying surgical excellence since 1996</h2>
      <p class="avm-video__body">AVM Healthcare Products Pvt. Ltd. is a New Delhi–based manufacturer and supplier of advanced quality surgical instruments and medical devices. We design, develop, and supply instruments across neurosurgery, general surgery, cardiovascular, gynaecology, plastic surgery, and more — serving premier institutions including AIIMS, Medanta, Fortis, Apollo, and KEM Hospital.</p>
      <blockquote class="avm-video__pullquote">
        Our motto is to provide world-class instruments for the benefit of mankind.
      </blockquote>
    </div>
    <div>
      <div class="avm-video__embed-wrap">
        <iframe
          src="https://www.youtube.com/embed/_QNRNKJiNuA"
          title="Who We Are — AVM Healthcare Products"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AVM Video Intro",
  "settings": [],
  "presets": [{ "name": "AVM Video Intro" }]
}
{% endschema %}
