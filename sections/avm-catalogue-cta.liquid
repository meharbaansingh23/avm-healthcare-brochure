<style>
  .avm-cta-wrap {
    background: #F4F8FD;
    padding: 80px 3rem;
  }

  .avm-cta-block {
    max-width: 1200px;
    margin: 0 auto;
    background: #0C447C;
    border-radius: 8px;
    padding: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.4rem;
    flex-wrap: wrap;
  }

  .avm-cta-block__left {}

  .avm-cta-block__heading {
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 0.6rem;
  }

  .avm-cta-block__sub {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: 1.6;
    max-width: 560px;
  }

  @media screen and (max-width: 749px) {
    .avm-cta-wrap { padding: 60px 1.6rem; }
    .avm-cta-block { padding: 2.4rem 1.8rem; }
  }
</style>

<div class="avm-cta-wrap">
  <div class="avm-cta-block">
    <div class="avm-cta-block__left">
      <h3 class="avm-cta-block__heading">Get our detailed product catalogue</h3>
      <p class="avm-cta-block__sub">3,400+ instruments across 6 specialties — delivered to your inbox within one business day.</p>
    </div>
    <a href="/pages/request-catalogue" class="avm-btn avm-btn--bright" style="flex-shrink:0;">Request Full Catalogue</a>
  </div>
</div>

{% schema %}
{
  "name": "AVM Catalogue CTA",
  "settings": [],
  "presets": [{ "name": "AVM Catalogue CTA" }]
}
{% endschema %}
