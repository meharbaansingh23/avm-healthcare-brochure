<style>
  .avm-cta {
    background: #0A1F44;
    padding: 80px 0;
    text-align: center;
  }

  .avm-cta__inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2.4rem;
  }

  .avm-cta__rule {
    display: block;
    width: 50px;
    height: 1px;
    background: #B87D2A;
    margin: 0 auto 2.8rem;
  }

  .avm-cta__label {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #B87D2A;
    margin: 0 0 1.6rem;
    display: block;
  }

  .avm-cta__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2.8rem, 4.5vw, 4.8rem);
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 1.8rem;
    line-height: 1.14;
    letter-spacing: -0.025em;
  }

  .avm-cta__body {
    font-family: var(--font-body-family);
    font-size: 1.75rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 3.4rem;
  }

  .avm-cta__btn {
    display: inline-block;
    padding: 1.3rem 3.4rem;
    background: #B87D2A;
    color: #ffffff;
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 3px;
    border: 2px solid #B87D2A;
    transition: background 0.22s ease, border-color 0.22s ease;
  }

  .avm-cta__btn:hover {
    background: #9e6b22;
    border-color: #9e6b22;
  }

  @media screen and (max-width: 749px) {
    .avm-cta {
      padding: 60px 0;
    }
  }
</style>

<section class="avm-cta">
  <div class="avm-cta__inner">
    <span class="avm-cta__rule" aria-hidden="true"></span>
    <span class="avm-cta__label">Get the Complete Picture</span>
    <h2 class="avm-cta__heading">Request our detailed product catalogue</h2>
    <p class="avm-cta__body">Over 3,400 surgical instruments across 6 specialties — from neurosurgery to cardiovascular. Our team will send the full catalogue to you within one business day.</p>
    <a href="/pages/request-catalogue" class="avm-cta__btn">Request Full Catalogue</a>
  </div>
</section>

{% schema %}
{
  "name": "AVM Catalogue CTA",
  "settings": [],
  "presets": [
    {
      "name": "AVM Catalogue CTA"
    }
  ]
}
{% endschema %}
