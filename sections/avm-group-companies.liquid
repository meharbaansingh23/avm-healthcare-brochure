<style>
  .avm-group {
    background: #ffffff;
    padding: 7rem 0;
  }

  .avm-group__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .avm-group__label {
    font-family: var(--font-body-family);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #B87D2A;
    margin: 0 0 1.2rem;
    display: block;
  }

  .avm-group__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    font-weight: 700;
    color: #0A1F44;
    margin: 0 0 4rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .avm-group__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .avm-group__card {
    border: 1.5px solid #e0e4ec;
    border-radius: 10px;
    padding: 2.8rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .avm-group__card:hover {
    box-shadow: 0 6px 28px rgba(10,31,68,0.10);
    border-color: #c8cfd9;
  }

  .avm-group__logo-placeholder {
    width: 80px;
    height: 80px;
    background: #edf0f5;
    border-radius: 10px;
    margin-bottom: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avm-group__logo-placeholder svg {
    width: 36px;
    height: 36px;
    color: #c0c8d8;
  }

  .avm-group__company-name {
    font-family: var(--font-heading-family);
    font-size: 1.6rem;
    font-weight: 600;
    color: #0A1F44;
    margin: 0;
    line-height: 1.3;
  }

  @media screen and (max-width: 899px) {
    .avm-group__cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media screen and (max-width: 499px) {
    .avm-group__cards {
      grid-template-columns: 1fr;
    }

    .avm-group {
      padding: 4rem 0;
    }
  }
</style>

<section class="avm-group">
  <div class="avm-group__inner">
    <span class="avm-group__label">Our Group</span>
    <h2 class="avm-group__heading">Part of a larger family</h2>
    <div class="avm-group__cards">

      <div class="avm-group__card">
        <div class="avm-group__logo-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <p class="avm-group__company-name">AVM Healthcare Products</p>
      </div>

      <div class="avm-group__card">
        <div class="avm-group__logo-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </div>
        <p class="avm-group__company-name">AVM Surgicare</p>
      </div>

      <div class="avm-group__card">
        <div class="avm-group__logo-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <p class="avm-group__company-name">ANI Instruments</p>
      </div>

      <div class="avm-group__card">
        <div class="avm-group__logo-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
          </svg>
        </div>
        <p class="avm-group__company-name">Chaba Mediwise</p>
      </div>

    </div>
  </div>
</section>

