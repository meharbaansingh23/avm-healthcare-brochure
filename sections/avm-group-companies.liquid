<style>
  .avm-group {
    background: #ffffff;
    padding: 80px 0;
  }

  .avm-group__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .avm-group__header {
    margin-bottom: 3.2rem;
  }

  .avm-group__heading {
    font-size: clamp(2.4rem, 3vw, 3.6rem);
    font-weight: 700;
    color: #042C53;
    letter-spacing: -0.02em;
    line-height: 1.14;
    margin: 0.8rem 0 0;
  }

  /* 1px gap grid — gap color acts as border */
  .avm-group__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: #E8EEF5;
    border: 1px solid #E8EEF5;
    border-radius: 8px;
    overflow: hidden;
  }

  .avm-group__card {
    background: #ffffff;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    transition: background 0.18s ease;
  }

  .avm-group__card:hover {
    background: #F4F8FD;
  }

  .avm-group__logo {
    width: 80px;
    height: 60px;
    background: #F4F8FD;
    border-radius: 6px;
    border: 1px solid #E8EEF5;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .avm-group__logo svg {
    width: 28px;
    height: 28px;
    color: #85B7EB;
  }

  .avm-group__name {
    font-size: 12px;
    font-weight: 600;
    color: #042C53;
    margin: 0;
    line-height: 1.35;
  }

  @media screen and (max-width: 899px) {
    .avm-group__grid { grid-template-columns: repeat(2, 1fr); }
    .avm-group { padding: 60px 0; }
  }

  @media screen and (max-width: 499px) {
    .avm-group__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<section class="avm-group">
  <div class="avm-group__inner">
    <div class="avm-group__header">
      <span class="avm-label">Our group</span>
      <h2 class="avm-group__heading">Part of a larger family</h2>
    </div>
    <div class="avm-group__grid">

      <div class="avm-group__card">
        <div class="avm-group__logo" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <p class="avm-group__name">AVM Healthcare Products</p>
      </div>

      <div class="avm-group__card">
        <div class="avm-group__logo" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </div>
        <p class="avm-group__name">AVM Surgicare</p>
      </div>

      <div class="avm-group__card">
        <div class="avm-group__logo" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <p class="avm-group__name">ANI Instruments</p>
      </div>

      <div class="avm-group__card">
        <div class="avm-group__logo" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
          </svg>
        </div>
        <p class="avm-group__name">Chaba Mediwise</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "AVM Group of Companies",
  "settings": [],
  "presets": [{ "name": "AVM Group of Companies" }]
}
{% endschema %}
