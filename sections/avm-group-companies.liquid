<style>
  .avm-group {
    background: #FAFAFA;
    padding: var(--section-pad, 120px) 0;
  }

  .avm-group__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .avm-group__top {
    margin-bottom: 4rem;
  }

  .avm-group__label {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #2563EB;
    margin-bottom: 1rem;
  }

  .avm-group__h2 {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(32px, 3.5vw, 44px);
    font-weight: 400;
    color: #0A1628;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }

  .avm-group__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
  }

  .avm-group__card {
    border-top: 2px solid #E2E8F0;
    padding-top: 1.5rem;
    transition: border-color 0.2s ease;
  }

  .avm-group__card:hover {
    border-color: #2563EB;
  }

  .avm-group__logo {
    width: 120px;
    height: 50px;
    background: #E2E8F0;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    transition: background 0.2s ease;
  }

  .avm-group__card:hover .avm-group__logo {
    background: #DBEAFE;
  }

  .avm-group__logo-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #94A3B8;
  }

  .avm-group__name {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #0A1628;
    margin: 0 0 0.3rem;
    line-height: 1.35;
  }

  .avm-group__sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: #94A3B8;
    margin: 0;
  }

  @media screen and (max-width: 1024px) {
    .avm-group__cards { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
  }

  @media screen and (max-width: 767px) {
    .avm-group { padding: 64px 0; }
    .avm-group__inner { padding: 0 1.5rem; }
    .avm-group__cards { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  }
</style>

<section class="avm-group">
  <div class="avm-group__inner">

    <div class="avm-group__top">
      <span class="avm-group__label">Our group</span>
      <h2 class="avm-group__h2">Part of a larger family</h2>
    </div>

    <div class="avm-group__cards">

      <div class="avm-group__card">
        <div class="avm-group__logo" aria-hidden="true">
          <span class="avm-group__logo-text">Logo</span>
        </div>
        <p class="avm-group__name">AVM Healthcare Products</p>
        <p class="avm-group__sub">Parent company</p>
      </div>

      <div class="avm-group__card">
        <div class="avm-group__logo" aria-hidden="true">
          <span class="avm-group__logo-text">Logo</span>
        </div>
        <p class="avm-group__name">AVM Surgicare</p>
        <p class="avm-group__sub">Surgical solutions</p>
      </div>

      <div class="avm-group__card">
        <div class="avm-group__logo" aria-hidden="true">
          <span class="avm-group__logo-text">Logo</span>
        </div>
        <p class="avm-group__name">ANI Instruments</p>
        <p class="avm-group__sub">German precision</p>
      </div>

      <div class="avm-group__card">
        <div class="avm-group__logo" aria-hidden="true">
          <span class="avm-group__logo-text">Logo</span>
        </div>
        <p class="avm-group__name">Chaba Mediwise</p>
        <p class="avm-group__sub">Healthcare products</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "AVM Group of Companies",
  "settings": [],
  "presets": [{ "name": "AVM Group of Companies" }]
}
{% endschema %}
