<style>
  .avm-hero {
    position: relative;
    width: 100%;
    height: 90vh;
    min-height: 560px;
    overflow: hidden;
    font-family: var(--font-heading-family);
  }

  .avm-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s ease-in-out;
    background-size: cover;
    background-position: center;
  }

  .avm-hero__slide.is-active {
    opacity: 1;
  }

  .avm-hero__slide::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10,31,68,0.35) 0%, rgba(10,31,68,0.75) 100%);
  }

  .avm-hero__content {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 2rem;
  }

  .avm-hero__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2.4rem, 5vw, 5.2rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.15;
    max-width: 860px;
    margin: 0 0 1.6rem;
    letter-spacing: -0.02em;
  }

  .avm-hero__subtext {
    font-family: var(--font-body-family);
    font-size: clamp(1.5rem, 2vw, 2rem);
    color: rgba(255,255,255,0.88);
    max-width: 560px;
    margin: 0 0 2.8rem;
    font-weight: 400;
    line-height: 1.5;
  }

  .avm-hero__buttons {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .avm-hero__btn {
    display: inline-block;
    padding: 1.1rem 2.6rem;
    font-family: var(--font-body-family);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 4px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .avm-hero__btn--filled {
    background: #0A1F44;
    color: #ffffff;
    border: 2px solid #0A1F44;
  }

  .avm-hero__btn--filled:hover {
    background: #0d2a5c;
    border-color: #0d2a5c;
  }

  .avm-hero__btn--outline {
    background: transparent;
    color: #ffffff;
    border: 2px solid #ffffff;
  }

  .avm-hero__btn--outline:hover {
    background: rgba(255,255,255,0.12);
  }

  .avm-hero__dots {
    position: absolute;
    bottom: 2.4rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    gap: 0.8rem;
  }

  .avm-hero__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.45);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .avm-hero__dot.is-active {
    background: #B87D2A;
    transform: scale(1.25);
  }

  @media screen and (max-width: 749px) {
    .avm-hero {
      height: 80vh;
      min-height: 480px;
    }
  }
</style>

<section class="avm-hero" id="avm-hero-{{ section.id }}">
  <div
    class="avm-hero__slide is-active"
    style="background-image: url('https://images.unsplash.com/photo-1530026405186-ed1f139313f3?w=1600&auto=format&fit=crop&q=80');"
  ></div>
  <div
    class="avm-hero__slide"
    style="background-image: url('https://images.unsplash.com/photo-1551601651-2a8555f1a136?w=1600&auto=format&fit=crop&q=80');"
  ></div>
  <div
    class="avm-hero__slide"
    style="background-image: url('https://images.unsplash.com/photo-1504813184591-01572f98c85f?w=1600&auto=format&fit=crop&q=80');"
  ></div>

  <div class="avm-hero__content">
    <h1 class="avm-hero__heading">Precision Instruments for Modern Surgical Care</h1>
    <p class="avm-hero__subtext">Trusted by hospitals and surgical centres across India</p>
    <div class="avm-hero__buttons">
      <a href="/pages/request-catalogue" class="avm-hero__btn avm-hero__btn--filled">Request Catalogue</a>
      <a href="/pages/contact" class="avm-hero__btn avm-hero__btn--outline">Get in Touch</a>
    </div>
  </div>

  <div class="avm-hero__dots" role="tablist" aria-label="Slideshow navigation">
    <button class="avm-hero__dot is-active" data-index="0" role="tab" aria-label="Slide 1" aria-selected="true"></button>
    <button class="avm-hero__dot" data-index="1" role="tab" aria-label="Slide 2" aria-selected="false"></button>
    <button class="avm-hero__dot" data-index="2" role="tab" aria-label="Slide 3" aria-selected="false"></button>
  </div>
</section>

<script>
(function() {
  var hero = document.getElementById('avm-hero-{{ section.id }}');
  if (!hero) return;

  var slides = hero.querySelectorAll('.avm-hero__slide');
  var dots = hero.querySelectorAll('.avm-hero__dot');
  var current = 0;
  var total = slides.length;
  var timer;

  function goTo(index) {
    slides[current].classList.remove('is-active');
    dots[current].classList.remove('is-active');
    dots[current].setAttribute('aria-selected', 'false');
    current = (index + total) % total;
    slides[current].classList.add('is-active');
    dots[current].classList.add('is-active');
    dots[current].setAttribute('aria-selected', 'true');
  }

  function next() {
    goTo(current + 1);
  }

  function startTimer() {
    timer = setInterval(next, 5000);
  }

  function resetTimer() {
    clearInterval(timer);
    startTimer();
  }

  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      var idx = parseInt(this.getAttribute('data-index'), 10);
      goTo(idx);
      resetTimer();
    });
  });

  startTimer();
})();
</script>

{% schema %}
{
  "name": "AVM Hero Slideshow",
  "settings": [],
  "presets": [
    {
      "name": "AVM Hero Slideshow"
    }
  ]
}
{% endschema %}
