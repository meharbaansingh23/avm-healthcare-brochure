<style>
  /* ── Hero ───────────────────────────────────────────────── */
  .avm-hero {
    background: #ffffff;
    padding: var(--section-pad, 120px) 0 80px;
  }

  .avm-hero__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 3rem;
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 5rem;
    align-items: center;
  }

  /* ── Left column ─────────────────────────────────────────── */
  .avm-hero__eyebrow {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #2563EB;
    margin-bottom: 1.6rem;
  }

  .avm-hero__h1 {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(40px, 5.5vw, 68px);
    font-weight: 400;
    color: #0A1628;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
  }

  .avm-hero__sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 17px;
    color: #64748B;
    line-height: 1.75;
    max-width: 440px;
    margin: 0;
  }

  .avm-hero__buttons {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .avm-hero__btn-primary {
    display: inline-flex;
    align-items: center;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    background: #0A1628;
    color: #ffffff;
    padding: 13px 26px;
    border-radius: 6px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.18s ease;
    white-space: nowrap;
    min-height: 44px;
  }

  .avm-hero__btn-primary:hover { background: #111f38; color: #ffffff; }

  .avm-hero__btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #64748B;
    padding: 13px 18px;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: color 0.18s ease;
    white-space: nowrap;
    min-height: 44px;
  }

  .avm-hero__btn-ghost:hover { color: #0A1628; }

  /* Stats */
  .avm-hero__stats {
    display: flex;
    gap: 2.8rem;
    flex-wrap: wrap;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #E2E8F0;
  }

  .avm-hero__stat-num {
    display: block;
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 28px;
    font-weight: 400;
    color: #0A1628;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 4px;
  }

  .avm-hero__stat-label {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #94A3B8;
  }

  /* ── Right column — placeholder ─────────────────────────── */
  .avm-hero__right { position: relative; }

  .avm-hero__slides {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border: 1px solid #BFDBFE;
  }

  .avm-hero-placeholder {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .avm-hero-placeholder.is-active { opacity: 1; }

  .avm-hero-placeholder__label {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #93C5FD;
  }

  .avm-hero-placeholder__hint {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    color: #3B82F6;
  }

  /* Dots */
  .avm-hero__dots {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.2rem;
    justify-content: flex-start;
  }

  .avm-hero__dot {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avm-hero__dot::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #CBD5E1;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .avm-hero__dot.is-active::before {
    background: #2563EB;
    transform: scale(1.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .avm-hero-placeholder { transition: none; }
    .avm-hero__dot::before { transition: none; }
  }

  /* ── Client strip (inside section) ──────────────────────── */
  .avm-ticker {
    background: #FAFAFA;
    border-top: 1px solid #E2E8F0;
    border-bottom: 1px solid #E2E8F0;
    padding: 16px 0;
    margin-top: 80px;
  }

  .avm-ticker__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 3rem;
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .avm-ticker__label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #94A3B8;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .avm-ticker__names {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: #64748B;
    line-height: 1.6;
  }

  .avm-ticker__sep {
    color: #CBD5E1;
    margin: 0 0.5rem;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media screen and (max-width: 1024px) {
    .avm-hero__inner { grid-template-columns: 1fr 1fr; gap: 3rem; }
  }

  @media screen and (max-width: 767px) {
    .avm-hero { padding: 64px 0 0; }
    .avm-hero__inner { grid-template-columns: 1fr; gap: 2.5rem; padding: 0 1.5rem; }
    .avm-hero__right { order: -1; }
    .avm-hero__slides { aspect-ratio: 16 / 9; border-radius: 12px; }
    .avm-hero__stats { gap: 2rem; }
    .avm-ticker { margin-top: 48px; }
    .avm-ticker__inner { padding: 0 1.5rem; gap: 1rem; }
    .avm-ticker__names { font-size: 12px; }
  }
</style>

<section class="avm-hero" id="avm-hero-{{ section.id }}">
  <div class="avm-hero__inner">

    <!-- Left: text -->
    <div class="avm-hero__left">
      <span class="avm-hero__eyebrow avm-animate avm-animate--d1">Surgical instruments &middot; Made in India</span>
      <h1 class="avm-hero__h1 avm-animate avm-animate--d2">Precision instruments for modern surgical care</h1>
      <p class="avm-hero__sub avm-animate avm-animate--d3">AVM Healthcare Products supplies advanced surgical instruments to premier hospitals across India — from neurosurgery to cardiovascular care.</p>

      <div class="avm-hero__buttons avm-animate avm-animate--d4">
        <a href="/pages/request-catalogue" class="avm-hero__btn-primary">Request catalogue</a>
        <a href="/pages/about-us" class="avm-hero__btn-ghost">Watch our story &rarr;</a>
      </div>

      <div class="avm-hero__stats avm-animate avm-animate--d5">
        <div class="avm-hero__stat">
          <span class="avm-hero__stat-num">3,400+</span>
          <span class="avm-hero__stat-label">Products</span>
        </div>
        <div class="avm-hero__stat">
          <span class="avm-hero__stat-num">6</span>
          <span class="avm-hero__stat-label">Specialties</span>
        </div>
        <div class="avm-hero__stat">
          <span class="avm-hero__stat-num">36+</span>
          <span class="avm-hero__stat-label">Hospitals</span>
        </div>
        <div class="avm-hero__stat">
          <span class="avm-hero__stat-num">30+</span>
          <span class="avm-hero__stat-label">Years</span>
        </div>
      </div>
    </div>

    <!-- Right: styled placeholder slideshow -->
    <div class="avm-hero__right avm-animate avm-animate--d3">
      <div class="avm-hero__slides" aria-label="Product image slideshow">
        <div class="avm-hero-placeholder is-active">
          <span class="avm-hero-placeholder__label">Hero image placeholder</span>
          <span class="avm-hero-placeholder__hint">Replace with real product photography</span>
        </div>
        <div class="avm-hero-placeholder">
          <span class="avm-hero-placeholder__label">Hero image placeholder</span>
          <span class="avm-hero-placeholder__hint">Replace with real product photography</span>
        </div>
        <div class="avm-hero-placeholder">
          <span class="avm-hero-placeholder__label">Hero image placeholder</span>
          <span class="avm-hero-placeholder__hint">Replace with real product photography</span>
        </div>
      </div>

      <div class="avm-hero__dots" role="tablist" aria-label="Slideshow navigation">
        <button class="avm-hero__dot is-active" data-index="0" role="tab" aria-label="Slide 1" aria-selected="true"></button>
        <button class="avm-hero__dot" data-index="1" role="tab" aria-label="Slide 2" aria-selected="false"></button>
        <button class="avm-hero__dot" data-index="2" role="tab" aria-label="Slide 3" aria-selected="false"></button>
      </div>
    </div>

  </div>

  <!-- Client strip -->
  <div class="avm-ticker">
    <div class="avm-ticker__inner">
      <span class="avm-ticker__label">Trusted by</span>
      <span class="avm-ticker__names">
        AIIMS Delhi<span class="avm-ticker__sep">&middot;</span>Medanta<span class="avm-ticker__sep">&middot;</span>Fortis<span class="avm-ticker__sep">&middot;</span>Apollo<span class="avm-ticker__sep">&middot;</span>KEM Hospital<span class="avm-ticker__sep">&middot;</span>PGI Chandigarh<span class="avm-ticker__sep">&middot;</span>GB Pant<span class="avm-ticker__sep">&middot;</span>Lilavati<span class="avm-ticker__sep">&middot;</span>Sir Ganga Ram
      </span>
    </div>
  </div>

</section>

<script>
(function() {
  var hero = document.getElementById('avm-hero-{{ section.id }}');
  if (!hero) return;
  var slides = hero.querySelectorAll('.avm-hero-placeholder');
  var dots   = hero.querySelectorAll('.avm-hero__dot');
  var current = 0, total = slides.length, timer;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  function goTo(i) {
    slides[current].classList.remove('is-active');
    dots[current].classList.remove('is-active');
    dots[current].setAttribute('aria-selected', 'false');
    current = (i + total) % total;
    slides[current].classList.add('is-active');
    dots[current].classList.add('is-active');
    dots[current].setAttribute('aria-selected', 'true');
  }

  function start() { timer = setInterval(function(){ goTo(current + 1); }, 5000); }
  function reset() { clearInterval(timer); start(); }

  dots.forEach(function(d) {
    d.addEventListener('click', function() {
      goTo(parseInt(this.getAttribute('data-index'), 10));
      reset();
    });
  });

  start();
})();
</script>

{% schema %}
{
  "name": "AVM Hero",
  "settings": [],
  "presets": [{ "name": "AVM Hero" }]
}
{% endschema %}
