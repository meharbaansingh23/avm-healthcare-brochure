<style>
  .avm-hero {
    position: relative;
    width: 100%;
    min-height: 90vh;
    overflow: hidden;
    font-family: var(--font-heading-family);
  }

  .avm-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.1s ease-in-out;
    background-size: cover;
    background-position: center;
  }

  .avm-hero__slide.is-active {
    opacity: 1;
  }

  .avm-hero__slide::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
  }

  .avm-hero__content {
    position: relative;
    z-index: 10;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem;
  }

  .avm-hero__eyebrow {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #B87D2A;
    margin: 0 0 2rem;
    display: block;
  }

  .avm-hero__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(3.2rem, 5.5vw, 6rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.12;
    max-width: 900px;
    margin: 0 0 2rem;
    letter-spacing: -0.025em;
  }

  .avm-hero__subtext {
    font-family: var(--font-body-family);
    font-size: clamp(1.6rem, 2.2vw, 2rem);
    color: rgba(255, 255, 255, 0.86);
    max-width: 620px;
    margin: 0 0 3.2rem;
    font-weight: 400;
    line-height: 1.6;
  }

  .avm-hero__buttons {
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .avm-hero__btn {
    display: inline-block;
    padding: 1.2rem 2.8rem;
    font-family: var(--font-body-family);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    border-radius: 3px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease;
  }

  .avm-hero__btn--filled {
    background: #B87D2A;
    color: #ffffff;
    border: 2px solid #B87D2A;
  }

  .avm-hero__btn--filled:hover {
    background: #9e6b22;
    border-color: #9e6b22;
  }

  .avm-hero__btn--outline {
    background: transparent;
    color: #ffffff;
    border: 2px solid rgba(255, 255, 255, 0.8);
  }

  .avm-hero__btn--outline:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #ffffff;
  }

  .avm-hero__dots {
    position: absolute;
    bottom: 2.8rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    gap: 0.9rem;
  }

  .avm-hero__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.38);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .avm-hero__dot.is-active {
    background: #B87D2A;
    transform: scale(1.3);
  }

  @media screen and (max-width: 749px) {
    .avm-hero__content {
      min-height: 80vh;
      padding: 5rem 2rem;
    }

    .avm-hero {
      min-height: 80vh;
    }
  }
</style>

<section class="avm-hero" id="avm-hero-{{ section.id }}">
  <div
    class="avm-hero__slide is-active"
    style="background-image: url('https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=1600&q=80'); background-size: cover; background-position: center;"
  ></div>
  <div
    class="avm-hero__slide"
    style="background-image: url('https://images.unsplash.com/photo-1551190822-a9333d879b1f?w=1600&q=80'); background-size: cover; background-position: center;"
  ></div>
  <div
    class="avm-hero__slide"
    style="background-image: url('https://images.unsplash.com/photo-1516549655169-df83a0774514?w=1600&q=80'); background-size: cover; background-position: center;"
  ></div>

  <div class="avm-hero__content">
    <span class="avm-hero__eyebrow">An Innovative Company &middot; Made in India</span>
    <h1 class="avm-hero__heading">Precision Surgical Instruments for Modern Healthcare</h1>
    <p class="avm-hero__subtext">Indigenous surgical products developed in German collaboration — supplied to premier institutions across India and worldwide.</p>
    <div class="avm-hero__buttons">
      <a href="/pages/request-catalogue" class="avm-hero__btn avm-hero__btn--filled">Request Full Catalogue</a>
      <a href="/pages/contact" class="avm-hero__btn avm-hero__btn--outline">Get in Touch</a>
    </div>
  </div>

  <div class="avm-hero__dots" role="tablist" aria-label="Slideshow navigation">
    <button class="avm-hero__dot is-active" data-index="0" role="tab" aria-label="Slide 1" aria-selected="true"></button>
    <button class="avm-hero__dot" data-index="1" role="tab" aria-label="Slide 2" aria-selected="false"></button>
    <button class="avm-hero__dot" data-index="2" role="tab" aria-label="Slide 3" aria-selected="false"></button>
  </div>
</section>

<script>
(function() {
  var hero = document.getElementById('avm-hero-{{ section.id }}');
  if (!hero) return;

  var slides = hero.querySelectorAll('.avm-hero__slide');
  var dots = hero.querySelectorAll('.avm-hero__dot');
  var current = 0;
  var total = slides.length;
  var timer;

  function goTo(index) {
    slides[current].classList.remove('is-active');
    dots[current].classList.remove('is-active');
    dots[current].setAttribute('aria-selected', 'false');
    current = (index + total) % total;
    slides[current].classList.add('is-active');
    dots[current].classList.add('is-active');
    dots[current].setAttribute('aria-selected', 'true');
  }

  function next() { goTo(current + 1); }

  function startTimer() { timer = setInterval(next, 5000); }
  function resetTimer() { clearInterval(timer); startTimer(); }

  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      goTo(parseInt(this.getAttribute('data-index'), 10));
      resetTimer();
    });
  });

  startTimer();
})();
</script>

{% schema %}
{
  "name": "AVM Hero Slideshow",
  "settings": [],
  "presets": [
    {
      "name": "AVM Hero Slideshow"
    }
  ]
}
{% endschema %}
