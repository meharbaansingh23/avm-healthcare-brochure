<style>
  .avm-about * { box-sizing: border-box; }

  /* ── Shared inner ───────────────────────────────────────── */
  .avm-about__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  /* ── 1. Hero ─────────────────────────────────────────────── */
  .avm-about__hero {
    background: #042C53;
    padding: 80px 3rem;
  }

  .avm-about__hero-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .avm-about__hero-h1 {
    font-size: clamp(3rem, 4vw, 3.6rem);
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0.8rem 0 1.2rem;
    max-width: 640px;
  }

  .avm-about__hero-sub {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin: 0;
    max-width: 520px;
  }

  /* ── 2. Intro ────────────────────────────────────────────── */
  .avm-about__intro {
    background: #ffffff;
    padding: 80px 0;
  }

  .avm-about__intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .avm-about__intro-h2 {
    font-size: clamp(2.2rem, 2.8vw, 3.2rem);
    font-weight: 700;
    color: #042C53;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0.8rem 0 1.6rem;
  }

  .avm-about__intro-body {
    font-size: 14px;
    line-height: 1.85;
    color: #5F7A99;
    margin: 0 0 1.2rem;
  }

  .avm-about__intro-body:last-child { margin-bottom: 0; }

  /* Stat block */
  .avm-about__stats {
    border: 1px solid #E8EEF5;
    border-radius: 8px;
    overflow: hidden;
  }

  .avm-about__stat-row {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    padding: 1.4rem 1.8rem;
    border-bottom: 1px solid #E8EEF5;
  }

  .avm-about__stat-row:last-child { border-bottom: none; }

  .avm-about__stat-num {
    font-size: 32px;
    font-weight: 700;
    color: #042C53;
    letter-spacing: -0.02em;
    line-height: 1;
    min-width: 90px;
    flex-shrink: 0;
  }

  .avm-about__stat-label {
    font-size: 12px;
    color: #5F7A99;
    line-height: 1.4;
  }

  /* ── 3. Mission ──────────────────────────────────────────── */
  .avm-about__mission {
    background: #F4F8FD;
    padding: 80px 0;
  }

  .avm-about__section-header {
    margin-bottom: 3rem;
  }

  .avm-about__section-h2 {
    font-size: clamp(2.4rem, 3vw, 3.4rem);
    font-weight: 700;
    color: #042C53;
    letter-spacing: -0.02em;
    line-height: 1.14;
    margin: 0.8rem 0 0;
  }

  .avm-about__section-h2--white { color: #ffffff; }

  .avm-about__cards-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .avm-about__card {
    background: #ffffff;
    border: 1px solid #E8EEF5;
    border-top: 3px solid #378ADD;
    border-radius: 8px;
    padding: 2rem 1.8rem;
    transition: box-shadow 0.18s ease;
  }

  .avm-about__card:hover {
    box-shadow: 0 4px 20px rgba(4, 44, 83, 0.07);
  }

  .avm-about__card-title {
    font-size: 13px;
    font-weight: 700;
    color: #042C53;
    margin: 0 0 0.7rem;
    line-height: 1.3;
  }

  .avm-about__card-body {
    font-size: 13px;
    line-height: 1.75;
    color: #5F7A99;
    margin: 0;
  }

  /* ── 4. Certifications ──────────────────────────────────── */
  .avm-about__certs {
    background: #ffffff;
    padding: 80px 0;
  }

  .avm-about__cert-badges {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.4rem;
    margin-bottom: 4rem;
  }

  .avm-about__cert-badge {
    border: 1px solid #E8EEF5;
    border-radius: 8px;
    padding: 2rem 1.4rem;
    text-align: center;
    transition: box-shadow 0.18s ease;
  }

  .avm-about__cert-badge:hover {
    box-shadow: 0 4px 16px rgba(4, 44, 83, 0.07);
  }

  .avm-about__cert-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #E6F1FB;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    position: relative;
  }

  .avm-about__cert-icon::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #378ADD;
  }

  .avm-about__cert-name {
    font-size: 12px;
    font-weight: 700;
    color: #042C53;
    margin: 0;
  }

  /* Details table */
  .avm-about__table {
    width: 100%;
    border-collapse: collapse;
  }

  .avm-about__table tr {
    border-bottom: 1px solid #E8EEF5;
  }

  .avm-about__table tr:last-child { border-bottom: none; }

  .avm-about__table td {
    padding: 0.875rem 0;
    font-size: 13px;
    vertical-align: top;
    line-height: 1.5;
  }

  .avm-about__table td:first-child {
    width: 160px;
    color: #5F7A99;
    padding-right: 2rem;
    flex-shrink: 0;
  }

  .avm-about__table td:last-child {
    color: #042C53;
    font-weight: 500;
  }

  /* ── 5. Clients ─────────────────────────────────────────── */
  .avm-about__clients {
    background: #042C53;
    padding: 80px 0;
    text-align: center;
  }

  .avm-about__clients-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
    margin-top: 2.8rem;
  }

  .avm-about__pill {
    display: inline-block;
    padding: 6px 14px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.8);
    transition: border-color 0.18s ease, background 0.18s ease;
  }

  .avm-about__pill:hover {
    border-color: rgba(55, 138, 221, 0.5);
    background: rgba(55, 138, 221, 0.08);
  }

  /* ── 6. CTA ─────────────────────────────────────────────── */
  .avm-about__cta-wrap {
    background: #F4F8FD;
    padding: 80px 3rem;
  }

  .avm-about__cta-block {
    max-width: 1200px;
    margin: 0 auto;
    background: #0C447C;
    border-radius: 8px;
    padding: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.4rem;
    flex-wrap: wrap;
  }

  .avm-about__cta-h3 {
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .avm-about__cta-sub {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media screen and (max-width: 899px) {
    .avm-about__intro-grid,
    .avm-about__cards-3 {
      grid-template-columns: 1fr;
      gap: 2.4rem;
    }

    .avm-about__cert-badges {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 599px) {
    .avm-about__hero,
    .avm-about__intro,
    .avm-about__mission,
    .avm-about__certs,
    .avm-about__clients,
    .avm-about__cta-wrap {
      padding: 60px 1.6rem;
    }

    .avm-about__hero { padding: 60px 1.6rem; }
    .avm-about__cta-wrap { padding: 60px 1.6rem; }

    .avm-about__inner { padding: 0 1.6rem; }

    .avm-about__table td:first-child {
      width: auto;
      display: block;
      padding-bottom: 0;
    }

    .avm-about__table td:last-child { display: block; }
  }
</style>

<div class="avm-about">

  <!-- 1. Hero -->
  <section class="avm-about__hero">
    <div class="avm-about__hero-inner">
      <span class="avm-label">About us</span>
      <h1 class="avm-about__hero-h1">An innovative company, made in India</h1>
      <p class="avm-about__hero-sub">Indigenous surgical products developed in German collaboration — supplied to premier institutions across India and worldwide.</p>
    </div>
  </section>

  <!-- 2. Company Intro -->
  <section class="avm-about__intro">
    <div class="avm-about__inner">
      <div class="avm-about__intro-grid">

        <div>
          <span class="avm-accent-bar"></span>
          <span class="avm-label">Who we are</span>
          <h2 class="avm-about__intro-h2">The leading manufacturer of advanced surgical instruments</h2>
          <p class="avm-about__intro-body">AVM Healthcare Products Pvt. Ltd. is a New Delhi–based manufacturer and supplier of surgical instruments and medical devices. The company is engaged in the design, development, innovation, production, sales, and consultancy of all kinds of surgical instruments and equipment.</p>
          <p class="avm-about__intro-body">Our range spans neurosurgery, micro surgery, cranio surgery, plastic surgery, implants, spinal surgery, cardiovascular surgery, gynaecology, ENT, orthopaedics, and more. We supply to premier institutions across India and export to overseas markets.</p>
        </div>

        <div class="avm-about__stats">
          <div class="avm-about__stat-row">
            <span class="avm-about__stat-num">3,400+</span>
            <span class="avm-about__stat-label">Products in our catalogue</span>
          </div>
          <div class="avm-about__stat-row">
            <span class="avm-about__stat-num">36+</span>
            <span class="avm-about__stat-label">Client hospitals and institutions</span>
          </div>
